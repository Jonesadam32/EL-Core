{
    "name": "Project Management",
    "slug": "project-management",
    "version": "1.0.0",
    "description": "Complete project management system with phases, tasks, kanban boards, and team collaboration",
    "author": "Expanded Learning Solutions",

    "requires": {
        "el_core": "1.0.0",
        "php": "8.0",
        "modules": ["fluent-crm-integration"]
    },

    "capabilities": [
        "manage_projects",
        "create_projects",
        "edit_projects",
        "delete_projects",
        "view_projects",
        "manage_tasks",
        "assign_tasks",
        "update_project_status"
    ],

    "default_role_mapping": {
        "administrator": [
            "manage_projects",
            "create_projects",
            "edit_projects",
            "delete_projects",
            "view_projects",
            "manage_tasks",
            "assign_tasks",
            "update_project_status"
        ],
        "editor": [
            "create_projects",
            "edit_projects",
            "view_projects",
            "manage_tasks",
            "assign_tasks"
        ]
    },

    "database": {
        "version": 1,
        "tables": {
            "el_projects": {
                "id": "bigint(20) UNSIGNED NOT NULL AUTO_INCREMENT",
                "company_id": "bigint(20) UNSIGNED DEFAULT NULL COMMENT 'Fluent CRM company ID'",
                "contact_id": "bigint(20) UNSIGNED DEFAULT NULL COMMENT 'Fluent CRM contact ID'",
                "name": "varchar(255) NOT NULL",
                "type": "enum('expand_site','afterschool_guru','expand_partners','els_consulting') DEFAULT 'expand_site'",
                "status": "enum('discovery','in_progress','client_review','paused','completed','cancelled') DEFAULT 'discovery'",
                "staging_url": "varchar(500)",
                "live_url": "varchar(500)",
                "start_date": "date",
                "target_launch_date": "date",
                "actual_launch_date": "date",
                "notes": "text",
                "created_at": "datetime DEFAULT CURRENT_TIMESTAMP",
                "updated_at": "datetime DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP",
                "PRIMARY KEY": "(id)",
                "KEY company_id": "(company_id)",
                "KEY contact_id": "(contact_id)",
                "KEY status": "(status)",
                "KEY type": "(type)"
            },
            "el_phases": {
                "id": "bigint(20) UNSIGNED NOT NULL AUTO_INCREMENT",
                "project_id": "bigint(20) UNSIGNED NOT NULL",
                "template_id": "bigint(20) UNSIGNED",
                "name": "varchar(255) NOT NULL",
                "description": "text",
                "display_order": "int(11) DEFAULT 0",
                "status": "enum('not_started','in_progress','awaiting_client','completed','skipped') DEFAULT 'not_started'",
                "started_at": "datetime",
                "completed_at": "datetime",
                "created_at": "datetime DEFAULT CURRENT_TIMESTAMP",
                "updated_at": "datetime DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP",
                "PRIMARY KEY": "(id)",
                "KEY project_id": "(project_id)",
                "KEY template_id": "(template_id)",
                "KEY status": "(status)",
                "KEY display_order": "(display_order)"
            },
            "el_tasks": {
                "id": "bigint(20) UNSIGNED NOT NULL AUTO_INCREMENT",
                "phase_id": "bigint(20) UNSIGNED NOT NULL",
                "title": "varchar(255) NOT NULL",
                "description": "text",
                "assigned_to": "bigint(20) UNSIGNED",
                "status": "enum('todo','in_progress','completed','cancelled') DEFAULT 'todo'",
                "priority": "enum('low','normal','high','urgent') DEFAULT 'normal'",
                "due_date": "date",
                "display_order": "int(11) DEFAULT 0",
                "completed_at": "datetime",
                "created_at": "datetime DEFAULT CURRENT_TIMESTAMP",
                "updated_at": "datetime DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP",
                "PRIMARY KEY": "(id)",
                "KEY phase_id": "(phase_id)",
                "KEY assigned_to": "(assigned_to)",
                "KEY status": "(status)",
                "KEY priority": "(priority)",
                "KEY display_order": "(display_order)"
            },
            "el_files": {
                "id": "bigint(20) UNSIGNED NOT NULL AUTO_INCREMENT",
                "project_id": "bigint(20) UNSIGNED NOT NULL",
                "phase_id": "bigint(20) UNSIGNED",
                "attachment_id": "bigint(20) UNSIGNED NOT NULL",
                "file_name": "varchar(255) NOT NULL",
                "file_type": "varchar(50)",
                "file_size": "bigint(20)",
                "uploaded_by": "bigint(20) UNSIGNED NOT NULL",
                "description": "text",
                "created_at": "datetime DEFAULT CURRENT_TIMESTAMP",
                "PRIMARY KEY": "(id)",
                "KEY project_id": "(project_id)",
                "KEY phase_id": "(phase_id)",
                "KEY attachment_id": "(attachment_id)",
                "KEY uploaded_by": "(uploaded_by)"
            },
            "el_activity_log": {
                "id": "bigint(20) UNSIGNED NOT NULL AUTO_INCREMENT",
                "project_id": "bigint(20) UNSIGNED",
                "user_id": "bigint(20) UNSIGNED NOT NULL",
                "action": "varchar(100) NOT NULL",
                "entity_type": "varchar(50)",
                "entity_id": "bigint(20) UNSIGNED",
                "description": "text",
                "ip_address": "varchar(45)",
                "created_at": "datetime DEFAULT CURRENT_TIMESTAMP",
                "PRIMARY KEY": "(id)",
                "KEY project_id": "(project_id)",
                "KEY user_id": "(user_id)",
                "KEY action": "(action)",
                "KEY entity_type": "(entity_type)",
                "KEY created_at": "(created_at)"
            },
            "el_phase_templates": {
                "id": "bigint(20) UNSIGNED NOT NULL AUTO_INCREMENT",
                "project_type": "enum('expand_site','afterschool_guru','expand_partners','els_consulting') NOT NULL",
                "name": "varchar(255) NOT NULL",
                "description": "text",
                "display_order": "int(11) DEFAULT 0",
                "is_active": "tinyint(1) DEFAULT 1",
                "created_at": "datetime DEFAULT CURRENT_TIMESTAMP",
                "PRIMARY KEY": "(id)",
                "KEY project_type": "(project_type)",
                "KEY display_order": "(display_order)"
            }
        },
        "migrations": {}
    },

    "shortcodes": [],

    "settings": [
        {
            "key": "default_project_type",
            "label": "Default Project Type",
            "type": "string",
            "default": "expand_site",
            "description": "Default project type when creating new projects"
        },
        {
            "key": "enable_kanban_view",
            "label": "Enable Kanban View",
            "type": "boolean",
            "default": true,
            "description": "Show kanban board view option in projects"
        },
        {
            "key": "auto_create_phases",
            "label": "Auto-Create Phases",
            "type": "boolean",
            "default": true,
            "description": "Automatically create phases from templates when creating a new project"
        }
    ]
}
